#!/usr/bin/env python3

import argparse
import json
import shlex
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


FRONT_SUFFIX = "_FRONT_RAW"
REAR_SUFFIX = "_REAR_RAW"
OUTPUT_SUFFIX = "_DUAL_MS_RAW"


@dataclass
class AudioInfo:
    codec_name: str
    sample_rate: int
    channels: int


def run_command(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, capture_output=True, text=True)


def probe_audio(path: Path) -> AudioInfo:
    cmd = [
        "ffprobe",
        "-v",
        "error",
        "-select_streams",
        "a:0",
        "-show_entries",
        "stream=codec_name,sample_rate,channels",
        "-of",
        "json",
        str(path),
    ]
    result = run_command(cmd)
    if result.returncode != 0:
        raise RuntimeError(f"ffprobe failed for {path}: {result.stderr.strip()}")

    payload = json.loads(result.stdout)
    streams = payload.get("streams", [])
    if not streams:
        raise RuntimeError(f"No audio stream found in {path}")

    stream = streams[0]
    return AudioInfo(
        codec_name=stream["codec_name"],
        sample_rate=int(stream["sample_rate"]),
        channels=int(stream["channels"]),
    )


def find_pairs(root: Path) -> list[tuple[Path, Path, Path]]:
    pairs: list[tuple[Path, Path, Path]] = []

    for directory in [p for p in root.rglob("*") if p.is_dir()] + [root]:
        fronts: dict[str, Path] = {}
        rears: dict[str, Path] = {}

        for entry in directory.iterdir():
            if not entry.is_file():
                continue
            if entry.suffix.lower() != ".wav":
                continue

            stem_upper = entry.stem.upper()
            if stem_upper.endswith(FRONT_SUFFIX):
                prefix = entry.stem[: -len(FRONT_SUFFIX)]
                fronts[prefix.upper()] = entry
            elif stem_upper.endswith(REAR_SUFFIX):
                prefix = entry.stem[: -len(REAR_SUFFIX)]
                rears[prefix.upper()] = entry

        for prefix in sorted(set(fronts) & set(rears)):
            front = fronts[prefix]
            rear = rears[prefix]
            output = directory / f"{front.stem[:-len(FRONT_SUFFIX)]}{OUTPUT_SUFFIX}.wav"
            pairs.append((front, rear, output))

    return pairs


def merge_pair(front: Path, rear: Path, output: Path, overwrite: bool) -> None:
    front_info = probe_audio(front)
    rear_info = probe_audio(rear)

    if front_info.channels != 2:
        raise RuntimeError(f"{front} is not stereo")
    if rear_info.channels != 2:
        raise RuntimeError(f"{rear} is not stereo")
    if front_info.sample_rate != rear_info.sample_rate:
        raise RuntimeError(
            f"Sample rate mismatch: {front_info.sample_rate} != {rear_info.sample_rate}"
        )
    if front_info.codec_name != rear_info.codec_name:
        raise RuntimeError(
            f"Codec mismatch: {front_info.codec_name} != {rear_info.codec_name}"
        )
    if not front_info.codec_name.startswith("pcm_"):
        raise RuntimeError(
            f"Unsupported codec {front_info.codec_name} in {front}; expected PCM WAV"
        )

    cmd = [
        "ffmpeg",
        "-hide_banner",
        "-loglevel",
        "error",
        "-y" if overwrite else "-n",
        "-i",
        str(front),
        "-i",
        str(rear),
        "-filter_complex",
        (
            "[0:a][1:a]join=inputs=2:channel_layout=quad:"
            "map=0.0-FL|0.1-FR|1.0-BL|1.1-BR[a]"
        ),
        "-map",
        "[a]",
        "-map_metadata",
        "0",
        "-c:a",
        front_info.codec_name,
        "-ar",
        str(front_info.sample_rate),
        "-write_bext",
        "1",
        str(output),
    ]
    result = run_command(cmd)
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or f"ffmpeg failed for {output}")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Recursively find *_FRONT_RAW.wav and *_REAR_RAW.wav pairs and merge "
            "them into *_DUAL_MS_RAW.wav files."
        )
    )
    parser.add_argument("path", help="Root folder to scan recursively")
    parser.add_argument(
        "--overwrite",
        action="store_true",
        help="Overwrite existing *_DUAL_MS_RAW.wav files",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the pairs that would be processed without writing output",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    root = Path(args.path).expanduser().resolve()

    if not root.exists():
        print(f"Path does not exist: {root}", file=sys.stderr)
        return 1
    if not root.is_dir():
        print(f"Path is not a directory: {root}", file=sys.stderr)
        return 1

    pairs = find_pairs(root)
    if not pairs:
        print(f"No FRONT/REAR pairs found under {root}")
        return 0

    failures = 0

    for front, rear, output in pairs:
        if output.exists() and not args.overwrite:
            print(f"Skipping existing output: {output}")
            continue

        if args.dry_run:
            print(f"Would merge:\n  {front}\n  {rear}\n  -> {output}")
            continue

        print(f"Merging {front.name} + {rear.name} -> {output.name}")
        try:
            merge_pair(front, rear, output, args.overwrite)
        except Exception as exc:  # noqa: BLE001
            failures += 1
            print(f"Failed: {exc}", file=sys.stderr)

    if failures:
        print(f"Completed with {failures} failure(s)", file=sys.stderr)
        return 2

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
